# ── Microsoft / Azure AD (dashboard login) ─────────────────────────────────
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Turso (Screening Tool DB) ───────────────────────────────────────────────
VITE_TURSO_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your_turso_auth_token

# ── Firebase (Full Calculator) ───────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── REDCap (server-side only — set in Cloudflare Pages dashboard, NOT here) ──
# REDCAP_TOKEN=       ← Pages environment variable, never in the browser
# REDCAP_API_URL=     ← Pages environment variable, never in the browser
