# ── Microsoft / Azure AD (for dashboard login) ─────────────────────────────
# Register an app in Azure → App registrations → Authentication
# Add redirect URI: https://urology-ai.github.io/epsa-admin-dashboard/
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Turso (Screening Tool DB) ───────────────────────────────────────────────
VITE_TURSO_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your_turso_auth_token

# ── REDCap proxy (Cloudflare Worker) ───────────────────────────────────────
VITE_REDCAP_PROXY_URL=https://epsa-redcap-proxy.your-subdomain.workers.dev
# Must match the DASHBOARD_SECRET wrangler secret on the worker
VITE_DASHBOARD_SECRET=some_random_secret_string

# ── Firebase (Full Calculator — mirrors e-psa frontend .env) ────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
