# ── Microsoft / Azure AD (dashboard login) ─────────────────────────────────
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Turso (Screening Tool DB) ───────────────────────────────────────────────
VITE_TURSO_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your_turso_auth_token

# ── Server-side only — set in Cloudflare Pages dashboard, NOT here ──────────
# FIREBASE_SERVICE_ACCOUNT  ← full JSON from Firebase console → Service accounts
#                              (minify to one line before pasting)
# REDCAP_TOKEN              ← same value as wrangler secret on epsa-redcap-proxy
# REDCAP_API_URL            ← same value as wrangler secret on epsa-redcap-proxy
