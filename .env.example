# ── Build-time vars (set in Cloudflare Pages → Environment variables → Build) ──
# Also put in .env.local for local Vite dev
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Runtime vars (Cloudflare Pages → Settings → Environment variables) ────────
# These are NEVER shipped to the browser.

# Microsoft — for server-side MSAL token verification in Pages Functions
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Turso — Screening Tool DB (read-only token recommended)
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Firebase — paste full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# REDCap
REDCAP_TOKEN=your_redcap_api_token
REDCAP_API_URL=https://redcap.mountsinai.org/api/
